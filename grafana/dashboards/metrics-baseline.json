{
  "title": "Metrics Baseline",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "API RPS",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{route=~\"/api/orders.*|/api/payments.*\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API p95 latency",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API error rate",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..|4..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue depth",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "queue_depth",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider p95 latency",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(provider_request_duration_seconds_bucket[5m])) by (le, provider))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider error rate",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(provider_requests_total{status=\"error\"}[5m])) by (provider) / clamp_min(sum(rate(provider_requests_total[5m])) by (provider), 1)",
          "refId": "A"
        }
      ]
    }
  ]
}
