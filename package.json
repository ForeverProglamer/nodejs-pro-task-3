{
  "name": "task-3",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:docker": "nodemon --legacy-watch --watch src --ext ts,json --signal SIGTERM --exec \"node -r ts-node/register -r tsconfig-paths/register src/main.ts\"",
    "build": "nest build",
    "start:prod": "node dist/main.js",
    "db:generate": "typeorm-ts-node-commonjs -d data-source.ts migration:generate -p",
    "db:migrate": "typeorm-ts-node-commonjs -d data-source.ts migration:run",
    "db:revert": "typeorm-ts-node-commonjs -d data-source.ts migration:revert",
    "db:seed": "ts-node -r tsconfig-paths/register src/seed/seed.ts",
    "migration:run": "npm run db:migrate",
    "seed": "npm run db:seed",
    "concurrency:test": "ts-node -r tsconfig-paths/register scripts/concurrency-test.ts",
    "compose:up": "docker compose -f compose.yml -f compose.dev.yml --profile seed up -d --build",
    "compose:down": "docker compose -f compose.yml -f compose.dev.yml --profile seed down",
    "compose:ps": "docker compose -f compose.yml -f compose.dev.yml --profile seed ps -a"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/typeorm": "^11.0.0",
    "amqplib": "^0.10.9",
    "dotenv": "^16.4.5",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^24.0.4",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
