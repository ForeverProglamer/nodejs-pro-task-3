{
  "name": "task-3",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:docker": "nodemon --legacy-watch --watch src --ext ts,json --signal SIGTERM --exec \"node -r ts-node/register -r tsconfig-paths/register src/main.ts\"",
    "build": "nest build",
    "start:prod": "node dist/main.js",
    "db:generate": "typeorm-ts-node-commonjs -d data-source.ts migration:generate -p",
    "db:migrate": "typeorm-ts-node-commonjs -d data-source.ts migration:run",
    "db:revert": "typeorm-ts-node-commonjs -d data-source.ts migration:revert",
    "db:seed": "ts-node -r tsconfig-paths/register src/seed/cli.ts",
    "migration:run": "npm run db:migrate",
    "seed": "npm run db:seed",
    "concurrency:test": "ts-node -r tsconfig-paths/register scripts/concurrency-test.ts",
    "compose:up": "docker compose -f compose.yml -f compose.dev.yml --profile seed up -d --build",
    "compose:down": "docker compose -f compose.yml -f compose.dev.yml --profile seed down",
    "compose:ps": "docker compose -f compose.yml -f compose.dev.yml --profile seed ps -a",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --runInBand --config ./test/jest-e2e.json",
    "prod:db:migrate": "typeorm -d dist/data-source.js migration:run",
    "prod:seed": "node dist/src/seed/cli.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/typeorm": "^11.0.0",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.17",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/rabbitmq": "^11.14.0",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.4",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
